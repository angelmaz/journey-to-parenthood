---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('blog');

const sortedPosts = posts.sort(
  (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime()
);
---

<BaseLayout
  title="Blog | Journey to Parenthood"
  description="Explore articles about pregnancy, labor, birth preparation, and postpartum healing."
>
  <section class="blog-page">
    <div class="blog-hero">
      <h1>Blog</h1>
      <p>
        Explore articles about pregnancy, labor, birth preparation, and postpartum healing.
      </p>
    </div>

    <div class="blog-grid">
      {sortedPosts.map((post) => (
        <article class="blog-card">
          <a class="blog-card-link" href={`/blog/${post.id}/`}>
            <div class="blog-card-image">
              <img src={post.data.heroImage} alt={post.data.title} />
            </div>

            <div class="blog-card-body">
              <div class="blog-meta">
                <span>{post.data.category}</span>
                <span>
                  {post.data.pubDate.toLocaleDateString('en-US', {
                    year: 'numeric',
                    month: 'long',
                    day: 'numeric'
                  })}
                </span>
              </div>

              <h2>{post.data.title}</h2>
              <p>{post.data.description}</p>

              <span class="blog-read">Read Article →</span>
            </div>
          </a>
        </article>
      ))}
    </div>
  </section>

  <style>
    .blog-page {
      max-width: 1200px;
      margin: 0 auto;
      padding: 56px 20px 80px;
    }

    .blog-hero {
      text-align: center;
      margin-bottom: 40px;
    }

    .blog-hero h1 {
      font-size: 2.8rem;
      margin-bottom: 12px;
    }

    .blog-hero p {
      max-width: 760px;
      margin: 0 auto;
      color: var(--taupe-light);
      font-size: 1rem;
      line-height: 1.6;
    }

    .blog-grid {
      display: grid !important;
      grid-template-columns: repeat(3, minmax(0, 1fr)) !important;
      gap: 28px;
      align-items: start;
    }

    .blog-card {
      background: var(--white);
      border-radius: 20px;
      overflow: hidden;
      border: 1px solid rgba(239, 201, 194, 0.35);
      box-shadow: 0 10px 30px rgba(0,0,0,0.05);
      transition: all 0.25s ease;
    }

    .blog-card:hover {
      transform: translateY(-6px);
      box-shadow: 0 18px 40px rgba(0,0,0,0.08);
    }

    .blog-card-link {
      display: block;
      color: inherit;
      text-decoration: none;
      height: 100%;
    }

    .blog-card-image {
      width: 100%;
      height: 220px;
      overflow: hidden;
      background: #f8f3ef;
    }

    .blog-card-image img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
      border-radius: 0;
    }

    .blog-card-body {
      padding: 20px;
    }

    .blog-meta {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
      font-size: 0.82rem;
      color: var(--taupe-light);
      margin-bottom: 10px;
    }

    .blog-card h2 {
      font-size: 1.3rem;
      line-height: 1.35;
      margin-bottom: 10px;
    }

    .blog-card p {
      display: -webkit-box;
      -webkit-line-clamp: 3;
      -webkit-box-orient: vertical;
      overflow: hidden;
}

    .blog-read {
      display: inline-flex;
      align-items: center;
      font-weight: 700;
      color: var(--blush);
    }

    @media (max-width: 1024px) {
      .blog-grid {
        grid-template-columns: repeat(2, minmax(0, 1fr)) !important;
      }
    }

    @media (max-width: 768px) {
      .blog-page {
        padding: 36px 16px 60px;
      }

      .blog-hero h1 {
        font-size: 2.2rem;
      }

      .blog-grid {
        grid-template-columns: 1fr !important;
        gap: 20px;
      }

      .blog-card-image {
        height: 220px;
      }
    }
  </style>
</BaseLayout>
