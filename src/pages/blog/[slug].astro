---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');

  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post }
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<BaseLayout
  title={`${post.data.title} | Journey to Parenthood`}
  description={post.data.description}
>

<article class="article-container">
  <a class="back-link" href="/blog/">← Back to blog</a>

  <img src={post.data.heroImage} alt={post.data.title} class="article-image" />

  <div class="article-meta">
    <span>{post.data.category}</span>
    <span>
      {post.data.pubDate.toLocaleDateString('en-US', {
        year:'numeric',
        month:'long',
        day:'numeric'
      })}
    </span>
  </div>

  <h1>{post.data.title}</h1>

  {post.data.subtitle && (
    <p class="subtitle">{post.data.subtitle}</p>
  )}

  <div class="content">
    <Content />
  </div>
</article>

<style>
  .article-container{
    max-width:850px;
    margin:60px auto;
    padding:30px;
    background:white;
    border-radius:18px;
    box-shadow:0 10px 30px rgba(0,0,0,0.05);
  }

  .article-image{
    width:100%;
    height:380px;
    object-fit:cover;
    border-radius:16px;
    margin-bottom:20px;
  }

  .article-meta{
    display:flex;
    gap:10px;
    font-size:0.85rem;
    color:#8a7f7f;
    margin-bottom:10px;
  }

  .subtitle{
    color:#8a7f7f;
    margin-bottom:20px;
  }

  .content :global(p){
    line-height:1.7;
    margin:12px 0;
  }

  .content :global(h2){
    margin-top:28px;
    margin-bottom:12px;
  }

  .content :global(h3){
    margin-top:22px;
    margin-bottom:10px;
  }

  .content :global(ul){
    margin:10px 0 10px 22px;
    list-style:disc;
  }

  .content :global(li){
    margin:8px 0;
  }

  .back-link{
    display:inline-block;
    margin-bottom:20px;
    text-decoration:none;
    color:#8a7f7f;
  }
</style>

</BaseLayout>