<script>
  (() => {
    const root = document.querySelector('.home-carousel');
    if (!root) return;

    const viewport = root.querySelector('.carousel-viewport');
    const track = root.querySelector('.carousel-track');
    const cards = Array.from(root.querySelectorAll('.blog-card'));
    const prev = root.querySelector('.carousel-prev');
    const next = root.querySelector('.carousel-next');
    const dotsWrap = document.querySelector('.carousel-dots');
    const hoverLeft = root.querySelector('.carousel-hover-left');
    const hoverRight = root.querySelector('.carousel-hover-right');

    let index = 0;
    let autoScrollFrame = null;
    let autoDirection = 0;

    function getPerView() {
      const w = window.innerWidth;
      if (w <= 768) return 1;
      if (w <= 1024) return 2;
      return 3;
    }

    function getMaxIndex() {
      return Math.max(0, cards.length - getPerView());
    }

    function cardStepPx() {
      const first = cards[0];
      if (!first) return 0;
      const cardW = first.getBoundingClientRect().width;
      const style = getComputedStyle(track);
      const gap = parseFloat(style.columnGap || style.gap || '0') || 0;
      return cardW + gap;
    }

    function clamp() {
      const maxIndex = getMaxIndex();
      index = Math.min(Math.max(index, 0), maxIndex);
    }

    function render() {
      clamp();
      const x = index * cardStepPx();
      track.style.transform = `translateX(-${x}px)`;
      updateDots();
      updateNav();
    }

    function updateNav() {
      const maxIndex = getMaxIndex();
      prev.disabled = index === 0;
      next.disabled = index === maxIndex;
      prev.style.opacity = prev.disabled ? '0.35' : '1';
      next.style.opacity = next.disabled ? '0.35' : '1';
    }

    function buildDots() {
      if (!dotsWrap) return;
      dotsWrap.innerHTML = '';
      const pages = getMaxIndex() + 1;

      for (let i = 0; i < pages; i++) {
        const b = document.createElement('button');
        b.type = 'button';
        b.className = 'carousel-dot';
        b.setAttribute('aria-label', `Go to slide ${i + 1}`);
        b.addEventListener('click', () => {
          index = i;
          render();
        });
        dotsWrap.appendChild(b);
      }

      updateDots();
    }

    function updateDots() {
      if (!dotsWrap) return;
      const dots = Array.from(dotsWrap.querySelectorAll('.carousel-dot'));
      dots.forEach((dot, i) => dot.classList.toggle('active', i === index));
    }

    function stepLeft() {
      index -= 1;
      render();
    }

    function stepRight() {
      index += 1;
      render();
    }

    function startHoverScroll(direction) {
      stopHoverScroll();
      autoDirection = direction;

      const loop = () => {
        const maxIndex = getMaxIndex();

        if (autoDirection === 1 && index < maxIndex) {
          index += 0.02;
        } else if (autoDirection === -1 && index > 0) {
          index -= 0.02;
        }

        index = Math.min(Math.max(index, 0), maxIndex);
        const x = index * cardStepPx();
        track.style.transform = `translateX(-${x}px)`;
        updateDots();
        updateNav();

        autoScrollFrame = requestAnimationFrame(loop);
      };

      autoScrollFrame = requestAnimationFrame(loop);
    }

    function stopHoverScroll() {
      if (autoScrollFrame) cancelAnimationFrame(autoScrollFrame);
      autoScrollFrame = null;
      index = Math.round(index);
      render();
    }

    prev?.addEventListener('click', stepLeft);
    next?.addEventListener('click', stepRight);

    hoverLeft?.addEventListener('mouseenter', () => startHoverScroll(-1));
    hoverRight?.addEventListener('mouseenter', () => startHoverScroll(1));
    hoverLeft?.addEventListener('mouseleave', stopHoverScroll);
    hoverRight?.addEventListener('mouseleave', stopHoverScroll);

    root.addEventListener('mouseleave', stopHoverScroll);

    let startX = 0;
    let isDown = false;

    viewport?.addEventListener('pointerdown', (e) => {
      isDown = true;
      startX = e.clientX;
    });

    viewport?.addEventListener('pointerup', (e) => {
      if (!isDown) return;
      isDown = false;
      const dx = e.clientX - startX;
      if (Math.abs(dx) < 40) return;
      if (dx < 0) stepRight();
      else stepLeft();
    });

    viewport?.addEventListener('pointercancel', () => {
      isDown = false;
    });

    window.addEventListener('resize', () => {
      buildDots();
      render();
    });

    buildDots();
    render();
  })();

  (() => {
    const newsletterForm = document.getElementById('newsletter-form');
    const newsletterMessage = document.getElementById('newsletter-message');
    const newsletterBox = document.getElementById('newsletter-box');
    const newsletterSuccess = document.getElementById('newsletter-success');

    if (!newsletterForm || !newsletterMessage || !newsletterBox || !newsletterSuccess) return;

    newsletterForm.addEventListener('submit', async (e) => {
      e.preventDefault();

      newsletterMessage.textContent = 'Sending...';

      const formData = new FormData(newsletterForm);
      const name = (formData.get('name') || '').toString().trim();
      const email = (formData.get('email') || '').toString().trim();

      try {
        const response = await fetch('/.netlify/functions/send-newsletter', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'Accept': 'application/json'
          },
          body: JSON.stringify({ name, email })
        });

        let result = {};

        try {
          result = await response.json();
        } catch (jsonError) {
          console.error('JSON parse error:', jsonError);
          throw new Error('Invalid server response');
        }

        console.log('Newsletter response:', response.status, result);

        if (response.ok && result.success) {
          newsletterForm.reset();
          newsletterMessage.textContent = '';
          newsletterBox.style.display = 'none';
          newsletterSuccess.style.display = 'block';
        } else {
          newsletterMessage.textContent =
            result.error || 'Something went wrong. Please try again.';
          console.error('Newsletter failed:', result);
        }
      } catch (error) {
        newsletterMessage.textContent = 'Something went wrong. Please try again.';
        console.error('Newsletter submit error:', error);
      }
    });
  })();
</script>